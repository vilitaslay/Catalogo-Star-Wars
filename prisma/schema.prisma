generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model Usuario {
  id       String @id @default(uuid())
  email    String @unique
  password String
  rol      Rol    @default(REGULAR)
}

model Pelicula {
  id             String    @id @default(uuid())
  swapiId        Int?      @unique
  titulo         String
  fecha_estreno  DateTime?
  episodio       Int?
  director       String?
  crawl_apertura String?
  descripcion    String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

enum Rol {
  REGULAR
  ADMINISTRADOR
}
